      "type": "string",
      "enum": [
        "\u062c\u062f\u064a\u062f",
        "\u062a\u062d\u062f\u064a\u062b",
        "\u062e\u0627\u0631\u062c\u064a",
        "\u0645\u0639\u062a\u0645\u062f"
