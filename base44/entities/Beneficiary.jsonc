      "type": "string",
      "description": "\u0627\u0633\u0645 \u0627\u0644\u0628\u0627\u062d\u062b \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a"
    },
    "notes": {
      "type": "string",
      "description": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0627\u0644\u062d\u0627\u0644\u0629"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u0631\u0648\u0627\u0628\u0637 \u0627\u0644\u0648\u062b\u0627\u0626\u0642 \u0648\u0627\u0644\u0635\u0648\u0631"
    },
    "visit_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0632\u064a\u0627\u0631\u0629 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629"
    },
    "approved_by": {
      "type": "string",
      "description": "\u0627\u0639\u062a\u0645\u0627\u062f \u0627\u0644\u0645\u062f\u064a\u0631"
    },
    "marketing_story": {
      "type": "string",
      "description": "\u0642\u0635\u0629 \u062a\u0633\u0648\u064a\u0642\u064a\u0629 \u0645\u0648\u0644\u0651\u062f\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b \u0644\u062d\u0645\u0644\u0627\u062a \u0627\u0644\u062a\u0628\u0631\u0639"
    }
  },
  "required": [
    "full_name",
    "phone",
    "city",
    "case_type",
    "priority"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "platform_admin"
          }
        },
        {
          "user_condition": {
            "role": "researcher"
          }
        },
        {
          "data.ngo_id": "{{user.data.ngo_id}}",
          "user_condition": {
            "role": "ngo_manager"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$in": [
                "platform_admin",
                "pdo"
              ]
            }
          }
        },
        {
          "created_by_id": "{{user.id}}",
          "user_condition": {
            "role": "researcher"
          }
        },
        {
          "data.ngo_id": "{{user.data.ngo_id}}",
          "user_condition": {
            "role": "ngo_manager"
          }
        },
        {
          "data.ngo_id": "{{user.data.ngo_id}}",
          "data.case_status": "\u0645\u0639\u062a\u0645\u062f",
          "user_condition": {
            "role": "marketer"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "platform_admin"
          }
        },
        {
          "created_by_id": "{{user.id}}",
          "user_condition": {
            "role": "researcher"
          }
        },
        {
          "data.ngo_id": "{{user.data.ngo_id}}",
          "user_condition": {
            "role": "ngo_manager"
          }
        },
        {
          "data.ngo_id": "{{user.data.ngo_id}}",
          "user_condition": {
            "role": "marketer"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "platform_admin"
          }
        },
        {
          "user_condition": {
            "role": "pdo"
          }
        }
      ]
    }
  }
}